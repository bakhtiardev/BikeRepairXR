  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentInstructionController
  instructionText: {fileID: 1975586780}
  nextButton: {fileID: 1564417165}
  prevButton: {fileID: 1496778299}
  videoPlayer: {fileID: 94653093}
  videoImage: {fileID: 94653094}
  instructions:
  - Welcome! Follow the instructions to complete the back wheel removal task. Use
    Left Controller X button to go Prev and Y button to go Next
  - 'Step 1: Grab the wrench from the working desk. Use the side trigger to grab
    the wrench'
  - 'Step 2: Use the wrench on the front wheel axle to unscrew it.'
  - 'Step 3: Once unscrewed, grab the back wheel with both hands, using the controllers
    front triggers. Then place the back wheel on the empty carpet'
  - You're all set! Great job completing the task.
  instructionVideos:
  - {fileID: 32900000, guid: 054a354d0b2ee68429812916a9948043, type: 3}
  - {fileID: 32900000, guid: 944ac6ace219e1544931236ecfcd1c19, type: 3}
